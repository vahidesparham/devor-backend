generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma-client"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  BULK
  LOGIN
  LOGOUT
  REFRESH
}

enum TextDirection {
  LTR
  RTL
}

enum BannerPlacement {
  A
  B
  C
  D
  E
}

enum AttributeSelectionMode {
  SINGLE
  MULTIPLE
}

enum BusinessEconomicLevel {
  LOW
  MEDIUM
  HIGH
}

enum BusinessOperationMode {
  INFO_ONLY
  SHOWCASE
  ORDERING
  BOOKING
  ORDERING_AND_BOOKING
}

enum BusinessUserRole {
  OWNER
  MANAGER
  STAFF
}

enum WeekDay {
  SATURDAY
  SUNDAY
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
}

model AdminUser {
  id             Int             @id @default(autoincrement())
  email          String          @unique @db.VarChar(191)
  firstName      String?         @db.VarChar(100)
  lastName       String?         @db.VarChar(100)
  avatar         String?         @db.VarChar(500)
  passwordHash   String          @db.VarChar(255)
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  adminUserRoles AdminUserRole[]
  refreshTokens  RefreshToken[]
  auditLogs      AuditLog[]
  errorLogs      ErrorLog[]
}

model Role {
  id             Int              @id @default(autoincrement())
  name           String           @unique @db.VarChar(191)
  title          String?          @db.VarChar(120)
  icon           String?          @db.VarChar(120)
  color          String?          @db.VarChar(30)
  description    String?          @db.VarChar(255)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  adminUserRoles AdminUserRole[]
  rolePermissions RolePermission[]
}

model Permission {
  id              Int              @id @default(autoincrement())
  key             String           @unique @db.VarChar(191)
  description     String?          @db.VarChar(255)
  createdAt       DateTime         @default(now())
  rolePermissions RolePermission[]
}

model AdminUserRole {
  adminUserId Int
  roleId      Int
  createdAt   DateTime @default(now())

  adminUser AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  role      Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([adminUserId, roleId])
}

model RolePermission {
  roleId       Int
  permissionId Int
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model RefreshToken {
  id                 Int       @id @default(autoincrement())
  adminId            Int
  tokenHash          String    @unique @db.VarChar(191)
  expiresAt          DateTime?
  revokedAt          DateTime?
  revokedReason      String?   @db.VarChar(255)
  replacedByTokenHash String?  @db.VarChar(191)
  createdByIp        String?   @db.VarChar(100)
  userAgent          String?   @db.VarChar(255)
  createdAt          DateTime  @default(now())

  admin AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
}

model Language {
  id                    Int                    @id @default(autoincrement())
  code                  String                 @unique @db.VarChar(20)
  name                  String                 @db.VarChar(100)
  nativeName            String?                @db.VarChar(100)
  direction             TextDirection          @default(LTR)
  isActive              Boolean                @default(true)
  isDefault             Boolean                @default(false)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  slideshowTranslations SlideshowTranslation[]
  bannerTranslations    BannerTranslation[]
  businessTranslations  BusinessTranslation[]
  serviceTypeTranslations ServiceTypeTranslation[]
  attributeGroupTranslations AttributeGroupTranslation[]
  attributeOptionTranslations AttributeOptionTranslation[]
  businessOfferingCategoryTranslations BusinessOfferingCategoryTranslation[]
  businessOfferingTranslations BusinessOfferingTranslation[]
  businessOfferingOptionGroupTranslations BusinessOfferingOptionGroupTranslation[]
  businessOfferingOptionTranslations BusinessOfferingOptionTranslation[]

  @@index([isActive])
}

model ImageConfig {
  id              Int      @id @default(autoincrement())
  code            String   @unique @db.VarChar(80)
  width           Int
  height          Int
  thumbnailWidth  Int
  thumbnailHeight Int
  folderName      String   @db.VarChar(120)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AuditLog {
  id        BigInt      @id @default(autoincrement())
  createdAt DateTime    @default(now())
  traceId   String?     @db.VarChar(100)
  adminId   Int?
  action    AuditAction
  entity    String      @db.VarChar(120)
  entityId  String?     @db.VarChar(120)
  method    String      @db.VarChar(10)
  path      String      @db.VarChar(255)
  ip        String?     @db.VarChar(100)
  userAgent String?     @db.VarChar(255)
  before    Json?
  after     Json?
  details   Json?

  admin AdminUser? @relation(fields: [adminId], references: [id], onDelete: SetNull)

  @@index([adminId])
  @@index([traceId])
  @@index([entity, entityId])
}

model ErrorLog {
  id         BigInt    @id @default(autoincrement())
  createdAt  DateTime  @default(now())
  traceId    String?   @db.VarChar(100)
  adminId    Int?
  method     String    @db.VarChar(10)
  path       String    @db.VarChar(255)
  query      Json?
  ip         String?   @db.VarChar(100)
  userAgent  String?   @db.VarChar(255)
  statusCode Int
  code       String    @db.VarChar(120)
  message    String    @db.VarChar(500)
  stack      String?   @db.Text
  details    Json?
  durationMs Float?

  admin AdminUser? @relation(fields: [adminId], references: [id], onDelete: SetNull)

  @@index([adminId])
  @@index([traceId])
  @@index([statusCode, code])
}


model Slideshow {
  id           Int                   @id @default(autoincrement())
  fromDate     DateTime?
  toDate       DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  translations SlideshowTranslation[]

  @@index([fromDate])
  @@index([toDate])
  @@index([createdAt])
}

model SlideshowTranslation {
  id          Int       @id @default(autoincrement())
  slideshowId Int
  lang        String    @db.VarChar(20)
  title       String    @db.VarChar(255)
  link        String?   @db.VarChar(500)
  image       String    @db.VarChar(500)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  slideshow Slideshow @relation(fields: [slideshowId], references: [id], onDelete: Cascade)
  language  Language  @relation(fields: [lang], references: [code], onDelete: Restrict, onUpdate: Cascade)

  @@unique([slideshowId, lang])
  @@index([lang, title])
  @@index([lang, isActive])
  @@index([slideshowId])
}

model Banner {
  id           Int                @id @default(autoincrement())
  placement    BannerPlacement
  fromDate     DateTime?
  toDate       DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  translations BannerTranslation[]

  @@index([placement])
  @@index([fromDate])
  @@index([toDate])
  @@index([createdAt])
}

model BannerTranslation {
  id        Int      @id @default(autoincrement())
  bannerId  Int
  lang      String   @db.VarChar(20)
  title     String   @db.VarChar(255)
  link      String?  @db.VarChar(500)
  image     String   @db.VarChar(500)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  banner   Banner   @relation(fields: [bannerId], references: [id], onDelete: Cascade)
  language Language @relation(fields: [lang], references: [code], onDelete: Restrict, onUpdate: Cascade)

  @@unique([bannerId, lang])
  @@index([lang, title])
  @@index([lang, isActive])
  @@index([bannerId])
}

model ServiceType {
  id                 Int                 @id @default(autoincrement())
  code               String              @unique @db.VarChar(80)
  title              String              @db.VarChar(160)
  image              String?             @db.VarChar(500)
  color              String?             @db.VarChar(30)
  description        String?             @db.VarChar(500)
  displayOrder       Int                 @default(0)
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  translations       ServiceTypeTranslation[]
  attributeGroups    AttributeGroup[]
  businesses         Business[]

  @@index([isActive, displayOrder])
}

model ServiceTypeTranslation {
  id            Int         @id @default(autoincrement())
  serviceTypeId Int
  lang          String      @db.VarChar(20)
  title         String      @db.VarChar(160)
  description   String?     @db.VarChar(500)
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  serviceType   ServiceType @relation(fields: [serviceTypeId], references: [id], onDelete: Cascade)
  language      Language    @relation(fields: [lang], references: [code], onDelete: Restrict, onUpdate: Cascade)

  @@unique([serviceTypeId, lang])
  @@index([lang, title])
  @@index([lang, isActive])
}

model AttributeGroup {
  id            Int                    @id @default(autoincrement())
  serviceTypeId Int
  code          String                 @db.VarChar(120)
  title         String                 @db.VarChar(160)
  image         String?                @db.VarChar(500)
  selectionMode AttributeSelectionMode @default(MULTIPLE)
  displayOrder  Int                    @default(0)
  isActive      Boolean                @default(true)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  serviceType   ServiceType            @relation(fields: [serviceTypeId], references: [id], onDelete: Cascade)
  translations  AttributeGroupTranslation[]
  options       AttributeOption[]

  @@unique([serviceTypeId, code])
  @@index([serviceTypeId, isActive, displayOrder])
}

model AttributeGroupTranslation {
  id        Int            @id @default(autoincrement())
  groupId   Int
  lang      String         @db.VarChar(20)
  title     String         @db.VarChar(160)
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  group     AttributeGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  language  Language       @relation(fields: [lang], references: [code], onDelete: Restrict, onUpdate: Cascade)

  @@unique([groupId, lang])
  @@index([lang, title])
  @@index([lang, isActive])
}

model AttributeOption {
  id                 Int                 @id @default(autoincrement())
  groupId            Int
  key                String              @db.VarChar(120)
  title              String              @db.VarChar(160)
  image              String?             @db.VarChar(500)
  color              String?             @db.VarChar(30)
  displayOrder       Int                 @default(0)
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  group              AttributeGroup      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  translations       AttributeOptionTranslation[]
  businessAttributes BusinessAttribute[]

  @@unique([groupId, key])
  @@index([groupId, isActive, displayOrder])
}

model AttributeOptionTranslation {
  id        Int             @id @default(autoincrement())
  optionId  Int
  lang      String          @db.VarChar(20)
  title     String          @db.VarChar(160)
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  option    AttributeOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  language  Language        @relation(fields: [lang], references: [code], onDelete: Restrict, onUpdate: Cascade)

  @@unique([optionId, lang])
  @@index([lang, title])
  @@index([lang, isActive])
}

model Business {
  id                 Int                   @id @default(autoincrement())
  serviceTypeId      Int
  slug               String                @unique @db.VarChar(160)
  logoImage          String?               @db.VarChar(500)
  coverImage         String?               @db.VarChar(500)
  phone              String?               @db.VarChar(80)
  email              String?               @db.VarChar(191)
  website            String?               @db.VarChar(500)
  latitude           Decimal?              @db.Decimal(10, 7)
  longitude          Decimal?              @db.Decimal(10, 7)
  economicLevel      BusinessEconomicLevel @default(MEDIUM)
  operationMode      BusinessOperationMode @default(INFO_ONLY)
  displayOrder       Int                   @default(0)
  isActive           Boolean               @default(true)
  isFeatured         Boolean               @default(false)
  showInLatest       Boolean               @default(false)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  serviceType        ServiceType           @relation(fields: [serviceTypeId], references: [id], onDelete: Restrict)
  translations       BusinessTranslation[]
  gallery            BusinessGallery[]
  workingHours       BusinessWorkingHour[]
  businessAttributes BusinessAttribute[]
  businessUsers      BusinessUser[]
  offeringCategories BusinessOfferingCategory[]
  offerings          BusinessOffering[]

  @@index([serviceTypeId, isActive, displayOrder])
  @@index([isFeatured])
  @@index([showInLatest])
  @@index([operationMode])
}

model BusinessTranslation {
  id             Int      @id @default(autoincrement())
  businessId     Int
  lang           String   @db.VarChar(20)
  title          String   @db.VarChar(255)
  summary        String?  @db.VarChar(500)
  description    String?  @db.Text
  address        String?  @db.VarChar(500)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  business       Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  language       Language @relation(fields: [lang], references: [code], onDelete: Restrict, onUpdate: Cascade)

  @@unique([businessId, lang])
  @@index([lang, title])
  @@index([lang, isActive])
}

model BusinessGallery {
  id           Int      @id @default(autoincrement())
  businessId   Int
  image        String   @db.VarChar(500)
  alt          String?  @db.VarChar(255)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, displayOrder])
}

model BusinessWorkingHour {
  id           Int      @id @default(autoincrement())
  businessId   Int
  dayOfWeek    WeekDay
  opensAt      String?  @db.VarChar(5)
  closesAt     String?  @db.VarChar(5)
  isClosed     Boolean  @default(false)
  note         String?  @db.VarChar(255)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, dayOfWeek, displayOrder])
  @@index([businessId, isClosed])
}

model BusinessAttribute {
  businessId        Int
  attributeOptionId Int
  createdAt         DateTime        @default(now())
  business          Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  attributeOption   AttributeOption @relation(fields: [attributeOptionId], references: [id], onDelete: Cascade)

  @@id([businessId, attributeOptionId])
}

model BusinessOfferingCategory {
  id           Int                                   @id @default(autoincrement())
  businessId   Int
  title        String                                @db.VarChar(160)
  image        String?                               @db.VarChar(500)
  displayOrder Int                                   @default(0)
  isActive     Boolean                               @default(true)
  createdAt    DateTime                              @default(now())
  updatedAt    DateTime                              @updatedAt
  business     Business                              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  translations BusinessOfferingCategoryTranslation[]
  offerings    BusinessOffering[]

  @@index([businessId, isActive, displayOrder])
}

model BusinessOfferingCategoryTranslation {
  id         Int                      @id @default(autoincrement())
  categoryId Int
  lang       String                   @db.VarChar(20)
  title      String                   @db.VarChar(160)
  isActive   Boolean                  @default(true)
  createdAt  DateTime                 @default(now())
  updatedAt  DateTime                 @updatedAt
  category   BusinessOfferingCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  language   Language                 @relation(fields: [lang], references: [code], onDelete: Restrict, onUpdate: Cascade)

  @@unique([categoryId, lang])
  @@index([lang, title])
  @@index([lang, isActive])
}

model BusinessOffering {
  id           Int                           @id @default(autoincrement())
  businessId   Int
  categoryId   Int?
  title        String                        @db.VarChar(180)
  image        String?                       @db.VarChar(500)
  basePrice    Decimal?                      @db.Decimal(12, 2)
  displayOrder Int                           @default(0)
  isActive     Boolean                       @default(true)
  createdAt    DateTime                      @default(now())
  updatedAt    DateTime                      @updatedAt
  business     Business                      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  category     BusinessOfferingCategory?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  translations BusinessOfferingTranslation[]
  optionGroups BusinessOfferingOptionGroup[]

  @@index([businessId, isActive, displayOrder])
  @@index([categoryId])
}

model BusinessOfferingTranslation {
  id          Int              @id @default(autoincrement())
  offeringId  Int
  lang        String           @db.VarChar(20)
  title       String           @db.VarChar(180)
  description String?          @db.Text
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  offering    BusinessOffering @relation(fields: [offeringId], references: [id], onDelete: Cascade)
  language    Language         @relation(fields: [lang], references: [code], onDelete: Restrict, onUpdate: Cascade)

  @@unique([offeringId, lang])
  @@index([lang, title])
  @@index([lang, isActive])
}

model BusinessOfferingOptionGroup {
  id            Int                                      @id @default(autoincrement())
  offeringId    Int
  title         String                                   @db.VarChar(160)
  selectionMode AttributeSelectionMode                   @default(MULTIPLE)
  isRequired    Boolean                                  @default(false)
  minSelect     Int                                      @default(0)
  maxSelect     Int?
  displayOrder  Int                                      @default(0)
  isActive      Boolean                                  @default(true)
  createdAt     DateTime                                 @default(now())
  updatedAt     DateTime                                 @updatedAt
  offering      BusinessOffering                         @relation(fields: [offeringId], references: [id], onDelete: Cascade)
  translations  BusinessOfferingOptionGroupTranslation[]
  options       BusinessOfferingOption[]

  @@index([offeringId, isActive, displayOrder])
}

model BusinessOfferingOptionGroupTranslation {
  id        Int                         @id @default(autoincrement())
  groupId   Int
  lang      String                      @db.VarChar(20)
  title     String                      @db.VarChar(160)
  isActive  Boolean                     @default(true)
  createdAt DateTime                    @default(now())
  updatedAt DateTime                    @updatedAt
  group     BusinessOfferingOptionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  language  Language                    @relation(fields: [lang], references: [code], onDelete: Restrict, onUpdate: Cascade)

  @@unique([groupId, lang])
  @@index([lang, title])
  @@index([lang, isActive])
}

model BusinessOfferingOption {
  id           Int                                  @id @default(autoincrement())
  groupId      Int
  title        String                               @db.VarChar(160)
  priceDelta   Decimal?                             @db.Decimal(12, 2)
  displayOrder Int                                  @default(0)
  isActive     Boolean                              @default(true)
  createdAt    DateTime                             @default(now())
  updatedAt    DateTime                             @updatedAt
  group        BusinessOfferingOptionGroup          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  translations BusinessOfferingOptionTranslation[]

  @@index([groupId, isActive, displayOrder])
}

model BusinessOfferingOptionTranslation {
  id        Int                    @id @default(autoincrement())
  optionId  Int
  lang      String                 @db.VarChar(20)
  title     String                 @db.VarChar(160)
  isActive  Boolean                @default(true)
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  option    BusinessOfferingOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  language  Language               @relation(fields: [lang], references: [code], onDelete: Restrict, onUpdate: Cascade)

  @@unique([optionId, lang])
  @@index([lang, title])
  @@index([lang, isActive])
}

model BusinessUser {
  id           Int              @id @default(autoincrement())
  businessId   Int
  email        String           @db.VarChar(191)
  phone        String?          @db.VarChar(80)
  passwordHash String           @db.VarChar(255)
  firstName    String?          @db.VarChar(100)
  lastName     String?          @db.VarChar(100)
  role         BusinessUserRole @default(STAFF)
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  business     Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, email])
  @@index([businessId, role])
  @@index([email])
  @@index([isActive])
}


