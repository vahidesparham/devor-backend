NODE_ENV=development
PORT=3001
DATABASE_URL="mysql://root:password@localhost:3306/global_api_admin"

JWT_SECRET="replace-with-long-random-secret"
JWT_REFRESH_SECRET="replace-with-long-random-refresh-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

CORS_ORIGINS="http://localhost:3000,http://localhost:3001,http://localhost:5173"
REQUEST_SIZE_LIMIT="1mb"

LOG_404_ERRORS=false
LOG_VALIDATION_ERRORS=false
ERROR_LOG_IGNORE_STATUS_CODES=401,403
ERROR_LOG_IGNORE_CODES=

SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="ChangeMe123!"
SEED_ADMIN_FIRST_NAME="System"
SEED_ADMIN_LAST_NAME="Admin"
SEED_ADMIN_AVATAR=""

