{
  "name": "global-api-admin-base",
  "version": "1.0.0",
  "description": "Production-ready Express admin API base with Prisma + MySQL",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "prisma:fix-encoding": "node scripts/strip-bom-prisma.js",
    "prisma:generate": "node scripts/strip-bom-prisma.js && prisma generate",
    "prisma:migrate": "node scripts/strip-bom-prisma.js && prisma migrate dev",
    "seed": "node scripts/strip-bom-prisma.js && node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "morgan": "^1.10.0",
    "nanoid": "^5.1.5",
    "sharp": "^0.34.4",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.9",
    "prisma": "^6.5.0"
  }
}
